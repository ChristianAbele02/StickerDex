# --- Stickerdex configuration ---

# Host port the web UI is published on by docker compose (open http://localhost:WEB_PORT)
WEB_PORT=8080

# Backend API
API_PORT=3001

# Path to the SQLite database file (created on first run)
DATABASE_PATH=./data/stickerdex.db

# Optional: protect write operations with a single shared password.
# Leave empty for open single-user mode (recommended only on a trusted LAN).
STICKERDEX_PASSWORD=

# Secret used to sign the auth cookie when STICKERDEX_PASSWORD is set.
# Change this to a long random string for any non-local deployment.
STICKERDEX_SECRET=change-me-to-a-long-random-string

# Frontend -> backend API base URL (used at build time by Vite)
VITE_API_BASE_URL=/api
