{
  "name": "@stickerdex/backend",
  "version": "0.1.0",
  "private": true,
  "description": "StickerDex REST API (Fastify + SQLite).",
  "license": "MIT",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc --noEmit",
    "start": "tsx src/index.ts",
    "generate-dataset": "tsx scripts/generate-dataset.ts",
    "generate-matches": "tsx scripts/generate-matches.ts",
    "generate-players": "tsx scripts/generate-players.ts",
    "generate-checklist": "tsx scripts/generate-checklist.ts",
    "seed": "tsx src/db/seed.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/static": "^7.0.4",
    "better-sqlite3": "^12.11.1",
    "fastify": "^4.28.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/node": "^20.14.0",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4",
    "vitest": "^2.1.1"
  }
}
